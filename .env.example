# Backend environment variables (all optional; sensible defaults in app/config.py)

# --- SEVIR dataset ---
# Point these at a local mirror of s3://sevir (see docs/SEVIR.md for download
# instructions). If unset, SEVIR_ROOT defaults to <repo>/sevir_data.
# SEVIR_ROOT=/path/to/sevir_data
# SEVIR_CATALOG_PATH=/path/to/sevir_data/CATALOG.csv
# SEVIR_DATA_DIR=/path/to/sevir_data/data

# Set to 1 to read HDF5 files directly from S3 instead of a local mirror.
# Requires network access + `pip install s3fs fsspec` (not used yet by
# SEVIRProvider in this milestone -- local-mirror mode is implemented first).
# SEVIR_USE_S3=0
